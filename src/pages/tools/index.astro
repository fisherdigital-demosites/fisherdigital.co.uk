---
import Layout from '../../layouts/Layout.astro';

const tools = [
  {
    slug: '/roi-calculator',
    name: 'Lost revenue calculator',
    label: 'Free tool',
    headline: 'Work out what a bad website is costing you.',
    summary: 'Plug in your trade, average job value, and city. We calculate how much revenue is leaking through a slow or non-existent website, and send you a free SEO audit of your current site.',
    cta: 'Run the calculator',
    accent: 'from-emerald-500/20 to-teal-500/10',
    icon: 'calculator',
  },
  {
    slug: '/ai-receptionist',
    name: 'AI receptionist demo',
    label: 'Free demo',
    headline: 'Never miss a call again. See it live.',
    summary: 'Our AI receptionist answers every call 24/7, books jobs into your calendar, and texts you a summary. Book a free 15-minute demo and we\'ll show it working with your real business.',
    cta: 'Book a demo',
    accent: 'from-indigo-500/20 to-purple-500/10',
    icon: 'phone',
  },
];
---

<Layout
  title="Free Tools for UK Tradespeople | FisherDigital"
  description="Free tools for UK local businesses: lost revenue calculator, free SEO audit, AI receptionist demo. No signup required, no credit card."
  schemaType="service"
>
  <!-- Hero -->
  <section class="section-light py-(--spacing-section)">
    <div class="mx-auto max-w-7xl px-6">
      <div class="max-w-3xl">
        <span class="label block mb-4">Free tools</span>
        <h1 class="text-5xl md:text-6xl font-heading font-600 tracking-tight mb-6">
          Try before<br />
          <span class="text-accent italic">you talk to us.</span>
        </h1>
        <p class="text-lg text-[var(--color-light-text-secondary)] max-w-xl mb-10 leading-relaxed">
          Tools we built for our own clients, now free for anyone. Find out
          what a weak website is costing you, or see our AI receptionist
          answer a call live. No signup, no pitch. Just useful.
        </p>
      </div>
    </div>
  </section>

  <!-- Tool cards -->
  <section class="bg-white py-(--spacing-section) border-t border-[var(--color-light-border)]/50">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {tools.map((tool) => (
          <a
            href={tool.slug}
            data-hover
            class={`group relative overflow-hidden rounded-2xl border border-[var(--color-light-border)] bg-gradient-to-br ${tool.accent} p-8 md:p-10 transition-all hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5`}
          >
            <div class="relative z-10 h-full flex flex-col">
              <div class="flex items-center justify-between mb-6">
                <span class="label text-[var(--color-light-muted)]">{tool.name}</span>
                <span class="text-[10px] uppercase tracking-wider font-600 px-3 py-1 rounded-full bg-accent/10 text-accent">
                  {tool.label}
                </span>
              </div>
              <h3 class="text-2xl md:text-3xl font-heading font-600 tracking-tight mb-4 text-[var(--color-light-text)] group-hover:text-accent transition-colors">
                {tool.headline}
              </h3>
              <p class="text-[var(--color-light-text-secondary)] leading-relaxed mb-8 flex-1">
                {tool.summary}
              </p>
              <span class="inline-flex items-center gap-2 text-sm font-600 text-accent">
                {tool.cta}
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-16 text-center max-w-2xl mx-auto">
        <p class="text-sm text-[var(--color-light-muted)] mb-6">
          More tools coming: SEO audits, booking widgets, AI chatbots. If
          there's something you wish existed, tell us.
        </p>
        <a href="/#contact" data-hover
          class="inline-flex items-center gap-3 bg-accent text-white px-8 py-4 rounded-full text-sm font-600 hover:bg-accent-hover transition-all shadow-lg shadow-accent/20 hover:shadow-accent/40">
          Request a tool
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
