---
import Layout from '../layouts/Layout.astro';

const apiBase = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8787';
---

<Layout
  title="Missed-Call Revenue Calculator | FisherDigital"
  description="Find out how much revenue your UK trade business is losing to missed calls. Free 30-second calculator with personalised audit."
  schemaType="service"
>
  <!-- Hero + calculator -->
  <section class="section-light py-(--spacing-section)">
    <div class="mx-auto max-w-5xl px-6">
      <div class="max-w-3xl mb-12">
        <span class="label block mb-4">Free tool</span>
        <h1 class="text-5xl md:text-6xl font-heading font-600 tracking-tight mb-6">
          How much is your phone<br />
          <span class="text-accent">costing you?</span>
        </h1>
        <p class="text-lg text-[var(--color-light-text-secondary)] max-w-xl leading-relaxed">
          UK trades lose 62% of inbound calls to voicemail, ring-out, or no answer. The industry average is <strong>£24,000 a year</strong> in missed revenue. Find your number in 30 seconds.
        </p>
      </div>

      <!-- Calculator card -->
      <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 md:p-12 shadow-xl">
        <form id="roi-form" class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="businessType" class="block text-sm font-600 mb-2">What's your trade?</label>
            <select
              id="businessType"
              name="businessType"
              required
              class="w-full rounded-lg border border-[var(--color-border)] px-4 py-3 bg-white focus:border-accent focus:outline-none"
            >
              <option value="">Pick one…</option>
              <option value="plumber">Plumber</option>
              <option value="electrician">Electrician</option>
              <option value="roofer">Roofer</option>
              <option value="builder">Builder</option>
              <option value="carpenter">Carpenter</option>
              <option value="dentist">Dentist</option>
              <option value="chiropractor">Chiropractor</option>
              <option value="accountant">Accountant</option>
              <option value="solicitor">Solicitor</option>
              <option value="restaurant">Restaurant</option>
              <option value="hair_salon">Hair Salon</option>
              <option value="nail_salon">Nail Salon</option>
              <option value="beauty_salon">Beauty Salon</option>
              <option value="garage">Garage / MOT</option>
              <option value="locksmith">Locksmith</option>
              <option value="landscaper">Landscaper</option>
              <option value="window_cleaner">Window Cleaner</option>
              <option value="cleaner">Cleaner</option>
              <option value="removals">Removals</option>
            </select>
          </div>

          <div>
            <label for="avgJobValue" class="block text-sm font-600 mb-2">Average job value (£)</label>
            <input
              id="avgJobValue"
              name="avgJobValue"
              type="number"
              min="10"
              step="10"
              placeholder="300"
              required
              class="w-full rounded-lg border border-[var(--color-border)] px-4 py-3 bg-white focus:border-accent focus:outline-none"
            />
          </div>

          <div>
            <label for="annualCalls" class="block text-sm font-600 mb-2">Annual calls (optional)</label>
            <input
              id="annualCalls"
              name="annualCalls"
              type="number"
              min="10"
              placeholder="We'll estimate if blank"
              class="w-full rounded-lg border border-[var(--color-border)] px-4 py-3 bg-white focus:border-accent focus:outline-none"
            />
          </div>

          <div>
            <label for="city" class="block text-sm font-600 mb-2">City</label>
            <input
              id="city"
              name="city"
              type="text"
              required
              placeholder="Bristol"
              class="w-full rounded-lg border border-[var(--color-border)] px-4 py-3 bg-white focus:border-accent focus:outline-none"
            />
          </div>

          <button
            type="submit"
            id="calc-btn"
            class="md:col-span-2 inline-flex items-center justify-center gap-3 bg-accent text-white px-8 py-4 rounded-full text-sm font-600 hover:bg-accent-hover transition-all shadow-lg shadow-accent/20 hover:shadow-accent/40"
          >
            Calculate my losses
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </button>
        </form>

        <!-- Result pane -->
        <div id="result" class="hidden mt-10 pt-10 border-t border-[var(--color-border)]">
          <p class="label mb-3">You're losing approximately</p>
          <p class="text-6xl md:text-7xl font-heading font-600 tracking-tight text-accent mb-2" id="result-number">£0</p>
          <p class="text-[var(--color-light-text-secondary)] mb-8">a year to missed calls.</p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
            <div class="rounded-xl bg-[var(--color-surface-light)] p-5">
              <p class="label mb-2">Missed calls / year</p>
              <p class="text-2xl font-heading font-600" id="result-missed">0</p>
            </div>
            <div class="rounded-xl bg-[var(--color-surface-light)] p-5">
              <p class="label mb-2">Lost jobs / year</p>
              <p class="text-2xl font-heading font-600" id="result-jobs">0</p>
            </div>
            <div class="rounded-xl bg-[var(--color-surface-light)] p-5">
              <p class="label mb-2">Avg job value</p>
              <p class="text-2xl font-heading font-600" id="result-value">£0</p>
            </div>
          </div>

          <!-- Capture form -->
          <div class="rounded-xl bg-[var(--color-surface-light)] p-8">
            <h3 class="text-2xl font-heading font-600 mb-3">Get a free personalised audit</h3>
            <p class="text-[var(--color-light-text-secondary)] mb-6">We'll put together a personalised report showing exactly how we'd fix this for your business. No obligation, no spam.</p>
            <form id="capture-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <input
                id="businessName"
                name="businessName"
                type="text"
                required
                placeholder="Business name"
                class="rounded-lg border border-[var(--color-border)] px-4 py-3 bg-white focus:border-accent focus:outline-none"
              />
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="Your email"
                class="rounded-lg border border-[var(--color-border)] px-4 py-3 bg-white focus:border-accent focus:outline-none"
              />
              <input
                id="phone"
                name="phone"
                type="tel"
                placeholder="Phone (optional)"
                class="md:col-span-2 rounded-lg border border-[var(--color-border)] px-4 py-3 bg-white focus:border-accent focus:outline-none"
              />
              <button
                type="submit"
                id="submit-btn"
                class="md:col-span-2 inline-flex items-center justify-center gap-3 bg-accent text-white px-8 py-4 rounded-full text-sm font-600 hover:bg-accent-hover transition-all"
              >
                Get my free audit
              </button>
            </form>
            <p id="capture-status" class="mt-4 text-sm hidden"></p>
          </div>
        </div>
      </div>

      <p class="text-xs text-[var(--color-light-text-secondary)] mt-6 max-w-2xl">
        <strong>How this is calculated:</strong> Industry research shows 62% of calls to UK trade businesses go unanswered. We multiply your annual call volume by that abandonment rate, then by the conversion rate for your specific trade, then by your average job value. Numbers are rounded; results are estimates.
      </p>
    </div>
  </section>

  <script define:vars={{ apiBase }}>
    const form = document.getElementById('roi-form');
    const result = document.getElementById('result');
    const captureForm = document.getElementById('capture-form');
    const captureStatus = document.getElementById('capture-status');
    let currentBreakdown = null;
    let currentInputs = null;

    function $(id) { return document.getElementById(id); }

    function formatGBP(n) {
      return '£' + Math.round(n).toLocaleString('en-GB');
    }

    async function postJSON(path, body) {
      const res = await fetch(apiBase + path, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json().catch(() => ({}));
      return { ok: res.ok, status: res.status, data };
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const annualCallsRaw = fd.get('annualCalls');
      const body = {
        businessType: fd.get('businessType'),
        city: fd.get('city'),
        avgJobValue: Number(fd.get('avgJobValue')),
      };
      if (annualCallsRaw) body.annualCalls = Number(annualCallsRaw);

      const btn = $('calc-btn');
      btn.disabled = true;
      btn.textContent = 'Calculating…';

      const res = await postJSON('/api/leadmagnet/roi-calculator', body);
      btn.disabled = false;
      btn.textContent = 'Calculate my losses';

      if (!res.ok) {
        alert((res.data && res.data.error) || 'Calculation failed');
        return;
      }

      currentBreakdown = res.data.breakdown;
      currentInputs = body;
      $('result-number').textContent = res.data.formatted.lostRevenue;
      $('result-missed').textContent = res.data.breakdown.missedCalls.toLocaleString('en-GB');
      $('result-jobs').textContent = res.data.breakdown.lostJobs.toLocaleString('en-GB');
      $('result-value').textContent = res.data.formatted.avgJobValue;
      result.classList.remove('hidden');
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    captureForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!currentInputs) return;

      const fd = new FormData(captureForm);
      const body = {
        ...currentInputs,
        businessName: fd.get('businessName'),
        email: fd.get('email'),
        firstTouchUrl: window.location.pathname,
      };
      const phoneRaw = fd.get('phone');
      if (phoneRaw) body.phone = phoneRaw;

      const btn = $('submit-btn');
      btn.disabled = true;
      btn.textContent = 'Sending…';
      captureStatus.className = 'mt-4 text-sm hidden';

      const res = await postJSON('/api/leadmagnet/roi-calculator/submit', body);
      btn.disabled = false;

      if (!res.ok) {
        captureStatus.textContent = (res.data && res.data.error) || 'Submission failed. Try again.';
        captureStatus.className = 'mt-4 text-sm text-red-600';
        btn.textContent = 'Get my free audit';
        return;
      }

      const msg = res.data.duplicate
        ? "We've already got your details — we'll be in touch soon."
        : "Thanks! Check your inbox in the next 24 hours for your personalised audit.";
      captureStatus.textContent = msg;
      captureStatus.className = 'mt-4 text-sm text-accent';
      btn.textContent = 'Sent';
    });
  </script>
</Layout>
