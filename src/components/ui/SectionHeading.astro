---
interface Props {
  label?: string;
  class?: string;
}

const { label, class: className = '' } = Astro.props;
---

<div class:list={['mb-16', className]}>
  {label && (
    <p class="text-accent text-sm font-mono font-medium uppercase tracking-widest mb-4">
      {label}
    </p>
  )}
  <slot name="title" />
  <slot name="description" />
</div>
