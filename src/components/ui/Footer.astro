---
const currentYear = new Date().getFullYear();

// Footer links — kept in sync with pages that actually exist.
// Rule: never link to a page that doesn't ship yet. If it's not in
// src/pages/, it doesn't go here.
const footerLinks = {
  services: [
    { label: 'Essential Websites', href: '#services' },
    { label: 'Professional Websites', href: '#services' },
    { label: 'Premium Websites', href: '#services' },
    { label: 'Online Booking', href: '#services' },
    { label: 'Search Optimisation', href: '#services' },
  ],
  // Only niches with a dedicated landing page live here. Add a niche row
  // ONLY after its /web-design-for-<niche>/ page ships in src/pages/.
  niches: [
    { label: 'Web Design for Plumbers', href: '/web-design-for-plumbers/' },
    { label: 'Web Design for Electricians', href: '/web-design-for-electricians/' },
    { label: 'Web Design for Dentists', href: '/web-design-for-dentists/' },
    { label: 'Web Design for Hair Salons', href: '/web-design-for-hair-salons/' },
    { label: 'Web Design for Restaurants', href: '/web-design-for-restaurants/' },
  ],
  company: [
    { label: 'About', href: '#about' },
    { label: 'Services', href: '#services' },
    { label: 'Our Process', href: '#process' },
    { label: 'Contact', href: '#contact' },
    { label: 'Privacy Policy', href: '/privacy/' },
    { label: 'Terms of Service', href: '/terms/' },
    { label: 'Cookie Policy', href: '/cookies/' },
  ],
};
---

<footer class="relative bg-base-darker border-t border-border mt-auto overflow-hidden">
  <!-- Large CTA headline -->
  <div class="mx-auto max-w-7xl px-6 pt-20 pb-16 border-b border-border">
    <h2 class="font-heading font-600 text-4xl md:text-5xl lg:text-6xl tracking-tight text-text leading-tight max-w-3xl">
      Ready to build something<br class="hidden md:block" /> worth visiting?
    </h2>
    <div class="mt-8">
      <a
        href="#contact"
        class="inline-flex items-center gap-3 rounded-full bg-accent px-8 py-4 text-base font-semibold text-white hover:bg-accent-hover transition-all shadow-lg shadow-accent/20 hover:shadow-accent/40"
        data-hover
        data-magnetic
      >
        Start a conversation
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M7 17l9.2-9.2M17 17V7.8H7.8" /></svg>
      </a>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-[32px] tracking-tight" style="font-family: 'Sora', sans-serif; font-weight: 700;">
          <span class="text-text">Fisher</span><span class="text-accent">Digital</span>
        </a>
        <p class="mt-4 text-sm text-text-muted leading-relaxed">
          Professional websites and smart tools<br />
          for local businesses.
        </p>
        <div class="mt-6 flex gap-4">
          <a href="https://linkedin.com" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-text-muted hover:text-accent transition-colors" data-hover>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram" class="text-text-muted hover:text-accent transition-colors" data-hover>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-sans text-sm font-semibold text-text uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-3">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-accent transition-colors" data-hover>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <h3 class="font-sans text-sm font-semibold text-text uppercase tracking-wider mb-4">Industries</h3>
        <ul class="space-y-3">
          {footerLinks.niches.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-accent transition-colors" data-hover>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-sans text-sm font-semibold text-text uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-text-muted hover:text-accent transition-colors" data-hover>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-border flex flex-col gap-4">
      <!-- Client name disclosure — pre-empts the "I googled them and found nothing"
           objection by making the privacy posture explicit up-front. Worded to
           read as a professionalism signal, not a hedge. -->
      <p class="text-[11px] text-text-muted/70 leading-relaxed max-w-3xl">
        <span class="font-semibold text-text-muted">A note on client names.</span>
        Some of the case studies and demo sites shown here use anonymised business names
        to protect our clients' competitive positioning and privacy. Real client
        references are available on request after an introductory call.
      </p>
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-2">
        <p class="text-xs text-text-muted">
          &copy; {currentYear} FisherDigital. All rights reserved.
        </p>
        <p class="text-xs text-text-muted">
          Bristol, United Kingdom
        </p>
      </div>
    </div>
  </div>
</footer>
