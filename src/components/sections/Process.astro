  paintbrush: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" />',
  message: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />',
  rocket: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a48.474 48.474 0 0 0-6.05-6.05c.21-.54.44-1.07.69-1.59C12.91 1.88 17.96.5 20.06.5c.55 0 1.02.2 1.41.59.39.39.59.86.59 1.41 0 2.1-1.38 7.15-6.22 9.82-.52.25-1.05.48-1.59.69l-.66-.64ZM13 15.92l-.64-.66c-.56.22-1.12.44-1.68.71C5.83 18.68.75 20.06.5 20.06c0 .55.2 1.02.59 1.41.39.39.86.59 1.41.59.84-.01 3.96-.58 7.5-2.97l3-3.17ZM8.54 12H4.5a1.5 1.5 0 0 1-1.06-.44L.44 8.56A1.5 1.5 0 0 1 1.5 6h4.06a48.25 48.25 0 0 0 2.98 6ZM12 15.46V19.5a1.5 1.5 0 0 0 .44 1.06l3 3A1.5 1.5 0 0 0 18 22.5v-4.06a48.25 48.25 0 0 1-6-2.98Z" />',
