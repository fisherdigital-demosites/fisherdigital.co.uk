};
---

<section id="process" class="section-light py-(--spacing-section)">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-20">
      <span class="label block mb-4">How it works</span>
      <h2 class="text-4xl md:text-5xl font-heading font-600 tracking-tight">
        Five steps to a website<br />
        <span class="text-[var(--color-light-muted)]">that works as hard as you do</span>
      </h2>
    </div>

    <!-- Horizontal timeline -->
    <div class="relative">
      <!-- Progress line -->
      <div class="hidden md:block absolute top-8 left-0 right-0 h-px bg-[var(--color-light-border)]">
        <div id="process-line" class="h-full bg-accent origin-left" style="transform: scaleX(0)"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 md:gap-6">
        {processSteps.map((step) => (
          <div class="process-step relative text-center md:text-left">
            <!-- Step number + icon -->
            <div class="relative z-10 mx-auto md:mx-0 w-16 h-16 rounded-full bg-white border border-[var(--color-light-border)] flex items-center justify-center shadow-sm mb-6">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={icons[step.icon]} />
              </svg>
            </div>

            <!-- Large serif number -->
            <p class="text-5xl font-heading font-600 text-accent/15 mb-2 tracking-tight">
              0{step.step}
            </p>

            <h3 class="text-lg font-heading font-600 mb-2 text-[var(--color-light-text)]">
              {step.title}
            </h3>
            <p class="text-sm text-[var(--color-light-text-secondary)] leading-relaxed">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initProcess() {
    const mm = gsap.matchMedia();
    mm.add('(min-width: 768px)', () => {
      gsap.from('.process-step', {
        scrollTrigger: { trigger: '#process', start: 'top 70%' },
        y: 40,
        opacity: 0,
        duration: 0.8,
        stagger: 0.12,
        ease: 'expo.out',
      });

      gsap.to('#process-line', {
        scaleX: 1,
        scrollTrigger: {
          trigger: '#process',
          start: 'top 60%',
          end: 'bottom 60%',
          scrub: 0.5,
        },
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProcess);
  } else {
    initProcess();
  }
</script>
