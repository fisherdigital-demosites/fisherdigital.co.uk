---
// Homepage teaser for the /tools hub. Highlights the two live tools with
// compact cards; the hub page carries the full treatment.
const tools = [
  {
    slug: '/roi-calculator',
    label: 'Calculator',
    headline: 'See what a bad website costs you',
    summary: 'Plug in your trade + average job value. Get a personalised lost-revenue estimate + free SEO audit.',
    cta: 'Run the calculator',
  },
  {
    slug: '/ai-receptionist',
    label: 'Live demo',
    headline: 'Hear our AI receptionist answer a call',
    summary: '24/7 voice agent that books jobs, captures leads, and texts you summaries. See it live in 15 mins.',
    cta: 'Book a demo',
  },
];
---

<section id="tools-teaser" class="bg-white py-(--spacing-section) border-t border-[var(--color-light-border)]/50">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl mb-14">
      <span class="label block mb-4">Free tools</span>
      <h2 class="text-4xl md:text-5xl font-heading font-600 tracking-tight mb-6 text-[var(--color-light-text)]">
        Try things<br />
        <span class="text-accent italic">before we talk.</span>
      </h2>
      <p class="text-lg text-[var(--color-light-text-secondary)] leading-relaxed">
        Free, useful, no signup. The fastest way to tell whether we're worth
        your 15 minutes.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {tools.map((tool) => (
        <a
          href={tool.slug}
          data-hover
          class="group relative overflow-hidden rounded-2xl border border-[var(--color-light-border)] bg-[#FAFAF8] p-8 md:p-10 transition-all hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5 hover:-translate-y-1"
        >
          <div class="flex items-center justify-between mb-6">
            <span class="text-[10px] uppercase tracking-wider font-600 px-3 py-1 rounded-full bg-accent/10 text-accent">
              {tool.label}
            </span>
            <svg class="w-5 h-5 text-[var(--color-light-muted)] group-hover:text-accent transition-all group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
          <h3 class="text-2xl md:text-[26px] font-heading font-600 tracking-tight mb-3 text-[var(--color-light-text)] group-hover:text-accent transition-colors">
            {tool.headline}
          </h3>
          <p class="text-[var(--color-light-text-secondary)] leading-relaxed mb-6">
            {tool.summary}
          </p>
          <span class="inline-flex items-center gap-2 text-sm font-600 text-accent">
            {tool.cta}
          </span>
        </a>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href="/tools" data-hover
        class="inline-flex items-center gap-2 text-sm font-600 text-accent hover:text-accent-hover transition-colors">
        See all free tools
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
