---
import { demoSites } from '../../data/portfolio';
---

<section id="portfolio" class="relative">
  <!-- Header -->
  <div class="section-light py-(--spacing-section) pb-12">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-4">
        <span class="label block mb-4">Our work</span>
        <h2 class="text-5xl md:text-6xl font-heading font-600 tracking-tight">
          What we build
        </h2>
        <p class="text-lg text-[var(--color-light-text-secondary)] max-w-2xl mx-auto mt-6">
          Real websites for real businesses. Each one built from scratch, tailored to the industry, and designed to bring in customers.
        </p>
      </div>
    </div>
  </div>

  <!-- Portfolio items -->
  {demoSites.map((site, index) => (
    <div
      class="portfolio-item relative section-light"
      data-index={index}
    >
      <div class="py-16 md:py-24">
        <div class="mx-auto max-w-7xl px-6 w-full">
          <div class:list={[
            'grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center',
          ]}>
            <!-- Device mockup with scrolling screenshot -->
            <div class:list={[
              'portfolio-device lg:col-span-7',
              index % 2 === 1 ? 'lg:order-2' : '',
            ]}>
              {site.device === 'laptop' ? (
                <!-- Laptop frame -->
                <div class="portfolio-mockup relative" style={`perspective: 1200px`}>
                  <div class="rounded-xl overflow-hidden border border-[var(--color-light-border)] shadow-2xl shadow-black/10 bg-white"
                    style={`transform: rotateY(${index % 2 === 0 ? '2' : '-2'}deg)`}>
                    <!-- Browser chrome -->
                    <div class="flex items-center gap-2 px-4 py-2.5 bg-[#f5f5f5] border-b border-[#e5e5e5]">
                      <div class="flex gap-1.5">
                        <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
                      </div>
                      <div class="flex-1 mx-4">
                        <div class="bg-white rounded-md px-3 py-1 text-[10px] text-[#999] font-mono border border-[#e0e0e0]">
                          {site.slug}.fisherdigital.co.uk
                        </div>
                      </div>
                    </div>
                    <!-- Scrolling screen -->
                    <div class="aspect-[16/10] relative overflow-hidden bg-white screen-viewport">
                      <iframe
                        src={`/demos/${site.slug}/index.html`}
                        title={`${site.businessName} preview`}
                        class="screen-content w-full border-0 pointer-events-none"
                        style="height: 300%; position: absolute; top: 0; left: 0;"
                        loading="lazy"
                        sandbox="allow-same-origin"
                      ></iframe>
                    </div>
                  </div>
                  <!-- Laptop base -->
                  <div class="mx-auto w-[55%] h-3 bg-[#e8e8e8] rounded-b-xl border-x border-b border-[#ddd]"></div>
                  <!-- Accent glow -->
                  <div class="absolute -inset-12 rounded-3xl opacity-[0.06] blur-[60px] -z-10"
                    style={`background: ${site.accentColor}`}></div>
                </div>
              ) : (
                <!-- Phone frame -->
                <div class="portfolio-mockup flex justify-center">
                  <div class="relative w-[280px] md:w-[320px]">
                    <div class="rounded-[2.5rem] overflow-hidden border-[6px] border-[#1a1a2e] shadow-2xl shadow-black/20 bg-white">
                      <!-- Phone notch -->
                      <div class="bg-[#1a1a2e] h-6 flex items-end justify-center pb-1">
                        <div class="w-20 h-4 bg-[#1a1a2e] rounded-b-xl"></div>
                      </div>
                      <!-- Scrolling screen -->
                      <div class="aspect-[9/16] relative overflow-hidden bg-white screen-viewport">
                        <iframe
                          src={`/demos/${site.slug}/index.html`}
                          title={`${site.businessName} preview`}
                          class="screen-content w-full border-0 pointer-events-none"
                          style="height: 300%; position: absolute; top: 0; left: 0;"
                          loading="lazy"
                          sandbox="allow-same-origin"
                        ></iframe>
                      </div>
                    </div>
                    <!-- Accent glow -->
                    <div class="absolute -inset-8 rounded-3xl opacity-[0.08] blur-[60px] -z-10"
                      style={`background: ${site.accentColor}`}></div>
                  </div>
                </div>
              )}
            </div>

            <!-- Info panel -->
            <div class:list={[
              'portfolio-info lg:col-span-5',
              index % 2 === 1 ? 'lg:order-1' : '',
            ]}>
              <span class="text-sm text-[var(--color-light-muted)] font-mono">{site.niche}</span>

              <h3 class="text-3xl md:text-4xl font-heading font-600 tracking-tight mb-5 mt-2">
                {site.businessName}
              </h3>

              <p class="text-[var(--color-light-text-secondary)] mb-8 leading-relaxed">{site.brief}</p>

              <span class="label block mb-3">What we delivered</span>
              <ul class="space-y-2.5 mb-10 portfolio-features">
                {site.results.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-[var(--color-light-text-secondary)]">
                    <span class="mt-1 shrink-0" style={`color: ${site.accentColor}`}>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider between items -->
      {index < demoSites.length - 1 && (
        <div class="mx-auto max-w-4xl px-6">
          <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-light-border)] to-transparent"></div>
        </div>
      )}
    </div>
  ))}

  <!-- CTA after portfolio -->
  <div class="section-light py-16 text-center">
    <a href="#contact" data-hover data-magnetic
      class="inline-flex items-center gap-3 bg-accent text-white px-8 py-4 rounded-full text-sm font-600 hover:bg-accent-hover transition-all shadow-lg shadow-accent/20 hover:shadow-accent/40">
      Like what you see? Book a free call
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initPortfolio() {
    document.querySelectorAll('.portfolio-item').forEach((section) => {
      const device = section.querySelector('.portfolio-device');
      const info = section.querySelector('.portfolio-info');
      const features = section.querySelectorAll('.portfolio-features li');
      const screenContent = section.querySelector('.screen-content');
      const index = parseInt((section as HTMLElement).dataset.index || '0');
      const fromLeft = index % 2 === 0;

      // Device + info entrance
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 65%',
          toggleActions: 'play none none reverse',
        },
      });

      tl.from(device, {
        x: fromLeft ? -80 : 80,
        opacity: 0,
        duration: 1,
        ease: 'expo.out',
      });

      if (info) {
        tl.from(info, {
          x: fromLeft ? 40 : -40,
          opacity: 0,
          duration: 0.8,
          ease: 'expo.out',
        }, '-=0.7');

        tl.from(features, {
          y: 15, opacity: 0, duration: 0.4,
          stagger: 0.06, ease: 'power2.out',
        }, '-=0.4');
      }

      // Scroll the iframe content as user scrolls the page
      if (screenContent) {
        gsap.to(screenContent, {
          y: '-66.6%', // scroll through the 300% height iframe
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top 80%',
            end: 'bottom 20%',
            scrub: 1.5,
          },
        });
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortfolio);
  } else {
    initPortfolio();
  }
</script>
