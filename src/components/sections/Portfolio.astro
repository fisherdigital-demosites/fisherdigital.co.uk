---
import { demoSites } from '../../data/portfolio';
---

<section id="portfolio" class="relative">
  <!-- Header -->
  <div class="section-light py-(--spacing-section) pb-12">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-4">
        <span class="label block mb-4">Our work</span>
        <h2 class="text-5xl md:text-6xl font-heading font-600 tracking-tight">
          What we build
        </h2>
        <p class="text-lg text-[var(--color-light-text-secondary)] max-w-2xl mx-auto mt-6">
          Real websites for real businesses. Each one built from scratch, tailored to the industry, and designed to bring in customers.
        </p>
      </div>
    </div>
  </div>

  <!-- ============================== -->
  <!-- ITEM 1: Westbury — 3D Monitor with scrolling site -->
  <!-- ============================== -->
  <div class="portfolio-item relative section-light" data-index="0" data-style="multi-device">
    <div class="py-20 md:py-32">
      <div class="mx-auto max-w-7xl px-6 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class="portfolio-device lg:col-span-7">
            <div class="floating-screen-scene" id="floating-screen-scene">
              <div class="fs-monitor" id="fs-wrap">
                <!-- Bezel highlight -->
                <div class="fs-bezel-highlight"></div>
                <!-- Inner bezel edge -->
                <div class="fs-bezel-inner"></div>
                <!-- Screen. Iframe uses data-src — the hydration script
                     below promotes it to src only on desktop, so mobile
                     never pays the cost of loading a full sub-document.
                     Mobile sees the static preview image instead. -->
                <div class="fs-screen screen-viewport">
                  <iframe data-src="/demos/westbury-plumbing/index.html" title="Westbury Plumbing preview" class="screen-content fs-iframe hidden md:block" loading="lazy" sandbox="allow-same-origin"></iframe>
                  <img src="/demos/westbury-plumbing/preview.jpg" alt="Westbury Plumbing site preview" class="demo-preview md:hidden" loading="lazy" decoding="async" />
                  <!-- Glass reflection layers -->
                  <div class="fs-glass"></div>
                  <div class="fs-glare"></div>
                </div>
              </div>
              <!-- Floating shadow -->
              <div class="fs-shadow"></div>
            </div>
          </div>

          <div class="portfolio-info lg:col-span-5">
            <span class="text-sm text-[var(--color-light-muted)] font-mono">Plumber</span>
            <h3 class="text-3xl md:text-4xl font-heading font-600 tracking-tight mb-5 mt-2">
              {demoSites[0].businessName}
            </h3>
            <p class="text-[var(--color-light-text-secondary)] mb-8 leading-relaxed">{demoSites[0].brief}</p>
            <span class="label block mb-3">What we delivered</span>
            <ul class="space-y-2.5 mb-10 portfolio-features">
              {demoSites[0].results.map((item) => (
                <li class="flex items-start gap-3 text-sm text-[var(--color-light-text-secondary)]">
                  <span class="mt-1 shrink-0" style="color: #C07A4A">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="mx-auto max-w-4xl px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-light-border)] to-transparent"></div>
    </div>
  </div>

  <!-- ============================== -->
  <!-- ITEM 2: Bright Smile — Floating 3D iPhone -->
  <!-- ============================== -->
  <div class="portfolio-item relative section-light" data-index="1" data-style="floating-phone">
    <div class="py-20 md:py-32">
      <div class="mx-auto max-w-7xl px-6 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class="portfolio-info lg:col-span-5 lg:order-1">
            <span class="text-sm text-[var(--color-light-muted)] font-mono">Dental Practice</span>
            <h3 class="text-3xl md:text-4xl font-heading font-600 tracking-tight mb-5 mt-2">
              {demoSites[1].businessName}
            </h3>
            <p class="text-[var(--color-light-text-secondary)] mb-8 leading-relaxed">{demoSites[1].brief}</p>
            <span class="label block mb-3">What we delivered</span>
            <ul class="space-y-2.5 mb-10 portfolio-features">
              {demoSites[1].results.map((item) => (
                <li class="flex items-start gap-3 text-sm text-[var(--color-light-text-secondary)]">
                  <span class="mt-1 shrink-0" style="color: #06b6d4">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="portfolio-device lg:col-span-7 lg:order-2">
            <div class="floating-phone-scene" id="floating-phone-scene">
              <div class="fp-device" id="fp-device">
                <!-- iPhone frame -->
                <div class="fp-frame">
                  <!-- Dynamic Island -->
                  <div class="fp-island"></div>
                  <!-- Screen — iframe rendered at 375px then scaled down for proper mobile layout -->
                  <div class="fp-screen">
                    <div class="fp-screen-inner screen-viewport">
                      <iframe data-src="/demos/bright-smile-dental/index.html" title="Bright Smile Dental preview" class="screen-content fp-iframe hidden md:block" loading="lazy" sandbox="allow-same-origin"></iframe>
                      <img src="/demos/bright-smile-dental/preview.jpg" alt="Bright Smile Dental site preview" class="demo-preview fp-preview md:hidden" loading="lazy" decoding="async" />
                    </div>
                  </div>
                </div>
                <!-- Side button -->
                <div class="fp-btn-power"></div>
                <div class="fp-btn-vol1"></div>
                <div class="fp-btn-vol2"></div>
                <!-- Reflection -->
                <div class="fp-reflection"></div>
              </div>
              <!-- Shadow -->
              <div class="fp-shadow"></div>
              <!-- Accent glow -->
              <div class="absolute -inset-16 rounded-full opacity-[0.07] blur-[80px] -z-10" style="background: #06b6d4"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="mx-auto max-w-4xl px-6">
      <div class="h-px bg-gradient-to-r from-transparent via-[var(--color-light-border)] to-transparent"></div>
    </div>
  </div>

  <!-- ============================== -->
  <!-- ITEM 3: Redwood — slide in from right, scroll iframe with page -->
  <!-- Prev iterations (removed 2026-04-11):
       1) Full-bleed "zoom to viewport" takeover — buggy on mid-range devices.
       2) Slide-in + pinned short-scroll — the pin pause felt wrong, broke
          the rhythm set by items 1 and 2.
       Current: slide-in entrance + standard scroll-linked iframe scrub so
       it reads as a third beat in the same cadence. Depth comes from a
       3D tilt on the frame (like item 1) with a deeper floating shadow
       and an accent glow, not from pinning or viewport takeover. -->
  <!-- ============================== -->
  <div class="portfolio-item relative section-light" data-index="2" data-style="slide-right">
    <div class="py-20 md:py-32">
      <div class="mx-auto max-w-7xl px-6 w-full">
        <!-- Info ABOVE the device for this one -->
        <div class="max-w-2xl mx-auto text-center mb-12 zoom-info">
          <span class="text-sm text-[var(--color-light-muted)] font-mono">Estate Agent</span>
          <h3 class="text-3xl md:text-4xl font-heading font-600 tracking-tight mb-5 mt-2">
            {demoSites[2].businessName}
          </h3>
          <p class="text-[var(--color-light-text-secondary)] mb-6 leading-relaxed">{demoSites[2].brief}</p>
          <div class="flex flex-wrap justify-center gap-6 portfolio-features">
            {demoSites[2].results.map((item) => (
              <span class="flex items-center gap-2 text-sm text-[var(--color-light-text-secondary)]">
                <svg class="w-3.5 h-3.5 shrink-0" style="color: #8b5cf6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- Depth-tilted frame with accent glow.
             .screen-viewport / .screen-content class names are shared
             with items 1 and 2 so the single iframe-scroll loop at the
             bottom of the script picks all three up — no bespoke
             timeline for Redwood. -->
        <div class="fb-scene" id="fb-scene">
          <div class="fb-frame" id="fb-frame">
            <!-- Bezel highlight like the item 1 monitor — sells the depth -->
            <div class="fb-bezel-highlight"></div>
            <div class="fb-screen screen-viewport" id="fb-screen">
              <iframe data-src="/demos/redwood-and-co/index.html" title="Redwood & Co preview" class="fb-iframe screen-content hidden md:block" loading="lazy" sandbox="allow-same-origin"></iframe>
              <img src="/demos/redwood-and-co/preview.jpg" alt="Redwood & Co site preview" class="demo-preview md:hidden" loading="lazy" decoding="async" />
              <!-- Glass reflection layers (match item 1) -->
              <div class="fb-glass"></div>
              <div class="fb-glare"></div>
            </div>
          </div>
          <!-- Floating shadow under the frame -->
          <div class="fb-shadow"></div>
          <!-- Accent glow — matches the purple colour used in the bullet ticks -->
          <div class="fb-glow"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA after portfolio -->
  <div class="section-light py-16 text-center">
    <a href="#contact" data-hover data-magnetic
      class="inline-flex items-center gap-3 bg-accent text-white px-8 py-4 rounded-full text-sm font-600 hover:bg-accent-hover transition-all shadow-lg shadow-accent/20 hover:shadow-accent/40">
      Like what you see? Book a free call
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>

<!-- ============================== -->
<!-- STYLES -->
<!-- ============================== -->
<style>
  /* ===== Shared: mobile preview image replacement =====
     Each demo iframe has a sibling <img src="preview.jpg"> that takes
     over on mobile via md:hidden/hidden md:block. The image fills the
     same slot as the iframe so the device frames look identical. */
  .demo-preview {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    border: 0;
  }
  /* Bright Smile's preview is mounted inside fp-screen-inner, which is
     itself scaled to fit the phone frame at 375px wide. The other
     items put the image directly in .screen-viewport at natural size. */
  .fp-preview {
    width: 375px;
    height: 812px;
  }

  /* ===== ITEM 1: Floating Monitor (21st.dev-inspired) ===== */
  .floating-screen-scene {
    position: relative;
    perspective: 1400px;
    padding: 2rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .fs-monitor {
    position: relative;
    width: 100%;
    padding: 16px;
    border-radius: 18px;
    background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 50%, #000 100%);
    box-shadow:
      0 50px 100px rgba(0,0,0,0.35),
      0 20px 60px rgba(0,0,0,0.25),
      0 8px 24px rgba(0,0,0,0.15);
    transform-style: preserve-3d;
    transform: rotateX(4deg) rotateY(0deg);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Bezel highlight — subtle gradient on frame */
  .fs-bezel-highlight {
    position: absolute; inset: 0;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 30%, transparent 70%, rgba(255,255,255,0.05) 100%);
    pointer-events: none;
    z-index: 2;
  }
  /* Inner bezel edge line */
  .fs-bezel-inner {
    position: absolute;
    inset: 8px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.03);
    pointer-events: none;
    z-index: 2;
  }
  .fs-screen {
    aspect-ratio: 16/10;
    position: relative;
    overflow: hidden;
    background: #000;
    border-radius: 8px;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05), inset 0 4px 20px rgba(0,0,0,0.8);
  }
  .fs-iframe {
    width: calc(100% + 20px);
    height: 300%;
    position: absolute;
    top: 0; left: 0;
    border: 0;
    pointer-events: none;
  }
  /* Glass reflection overlay */
  .fs-glass {
    position: absolute; inset: 0; border-radius: 8px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 40%, transparent 60%, rgba(255,255,255,0.04) 100%);
    pointer-events: none; z-index: 10;
  }
  /* Top glare highlight */
  .fs-glare {
    position: absolute;
    top: 0; left: 10%; right: 10%;
    height: 30%;
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, transparent 100%);
    pointer-events: none; z-index: 11;
  }
  /* Floating shadow beneath */
  .fs-shadow {
    width: 70%; height: 20px;
    margin: 1.5rem auto 0;
    background: radial-gradient(ellipse, rgba(0,0,0,0.12) 0%, transparent 70%);
    filter: blur(8px);
  }

  /* ===== ITEM 2: Floating 3D iPhone ===== */
  .floating-phone-scene {
    position: relative; perspective: 1400px;
    display: flex; justify-content: center;
    padding: 3rem 0;
  }
  .fp-device {
    position: relative; width: 300px;
    transform-style: preserve-3d;
    transform: rotateY(-14deg) rotateX(4deg);
    transition: transform 0.12s ease-out;
    animation: fpFloat 5s ease-in-out infinite;
  }
  @keyframes fpFloat {
    0%, 100% { transform: rotateY(-14deg) rotateX(4deg) translateY(0); }
    50% { transform: rotateY(-14deg) rotateX(4deg) translateY(-12px); }
  }
  .fp-frame {
    position: relative;
    border-radius: 2.75rem; overflow: hidden;
    border: 5px solid #2a2a3e;
    background: linear-gradient(145deg, #2e2e42 0%, #1a1a2e 50%, #2e2e42 100%);
    box-shadow:
      0 30px 80px rgba(0,0,0,0.2),
      0 4px 12px rgba(0,0,0,0.08),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .fp-island {
    position: absolute; top: 10px; left: 50%; transform: translateX(-50%);
    width: 90px; height: 26px; border-radius: 100px;
    background: #000; z-index: 20;
    box-shadow: inset 0 1px 3px rgba(0,0,0,0.5);
  }
  .fp-screen {
    aspect-ratio: 9/19.5; position: relative;
    overflow: hidden; background: white;
    border-radius: 2.25rem; margin: 2px;
  }
  .fp-screen-inner {
    width: 375px; height: 812px;
    transform-origin: top left;
    transform: scale(var(--fp-scale, 0.72));
    position: absolute; top: 0; left: 0;
    overflow: hidden;
  }
  .fp-iframe {
    width: 375px; height: 3000px; position: absolute;
    top: 0; left: 0; border: 0; pointer-events: none;
  }
  .fp-btn-power {
    position: absolute; right: -7px; top: 28%;
    width: 3px; height: 50px; border-radius: 0 3px 3px 0;
    background: linear-gradient(180deg, #444, #333, #444);
  }
  .fp-btn-vol1 {
    position: absolute; left: -7px; top: 22%;
    width: 3px; height: 28px; border-radius: 3px 0 0 3px;
    background: linear-gradient(180deg, #444, #333, #444);
  }
  .fp-btn-vol2 {
    position: absolute; left: -7px; top: 32%;
    width: 3px; height: 28px; border-radius: 3px 0 0 3px;
    background: linear-gradient(180deg, #444, #333, #444);
  }
  .fp-reflection {
    position: absolute; inset: 0; border-radius: 2.75rem;
    background: linear-gradient(125deg, rgba(255,255,255,0.12) 0%, transparent 35%, transparent 65%, rgba(255,255,255,0.04) 100%);
    pointer-events: none; z-index: 15;
  }
  .fp-shadow {
    width: 200px; height: 20px; margin: 1.5rem auto 0;
    background: radial-gradient(ellipse, rgba(0,0,0,0.1) 0%, transparent 70%);
    filter: blur(6px);
    animation: fpShadow 5s ease-in-out infinite;
  }
  @keyframes fpShadow {
    0%, 100% { transform: scaleX(1); opacity: 1; }
    50% { transform: scaleX(0.85); opacity: 0.7; }
  }

  /* ===== ITEM 3: Depth-tilted floating frame =====
     Static 3D tilt + deep floating shadow + purple accent glow.
     Iframe content is scroll-scrubbed by the shared iframe loop at the
     bottom of the <script> block, so this mirrors item 1's cadence. */
  .fb-scene {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5rem 0 3.5rem;
    perspective: 1600px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .fb-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    padding: 14px;
    border-radius: 20px;
    background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 55%, #000 100%);
    box-shadow:
      0 60px 120px rgba(14,10,35,0.28),
      0 30px 70px rgba(14,10,35,0.18),
      0 12px 32px rgba(0,0,0,0.15),
      inset 0 1px 0 rgba(255,255,255,0.06);
    transform-style: preserve-3d;
    transform: rotateX(6deg) rotateY(-2deg);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .fb-bezel-highlight {
    position: absolute;
    inset: 0;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 28%, transparent 70%, rgba(255,255,255,0.06) 100%);
    pointer-events: none;
    z-index: 2;
  }
  .fb-screen {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    border-radius: 10px;
    background: #fff;
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.05),
      inset 0 6px 28px rgba(0,0,0,0.55);
  }
  /* Iframe is taller than the frame so the scroll-scrub has travel.
     Matches item 1's 300% trick. */
  .fb-iframe {
    width: calc(100% + 20px);
    height: 300%;
    position: absolute;
    top: 0; left: 0;
    border: 0;
    pointer-events: none;
  }
  .fb-glass {
    position: absolute; inset: 0; border-radius: 10px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 40%, transparent 60%, rgba(255,255,255,0.04) 100%);
    pointer-events: none; z-index: 10;
  }
  .fb-glare {
    position: absolute;
    top: 0; left: 8%; right: 8%;
    height: 32%;
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(255,255,255,0.09) 0%, transparent 100%);
    pointer-events: none; z-index: 11;
  }
  .fb-shadow {
    width: 72%;
    height: 28px;
    margin-top: 2rem;
    background: radial-gradient(ellipse, rgba(20,10,40,0.22) 0%, transparent 70%);
    filter: blur(14px);
  }
  /* Purple accent glow matches the bullet tick colour on this item */
  .fb-glow {
    position: absolute;
    inset: -8% -6% -12% -6%;
    border-radius: 40px;
    background: radial-gradient(ellipse at center, rgba(139,92,246,0.22) 0%, rgba(139,92,246,0.08) 35%, transparent 70%);
    filter: blur(60px);
    z-index: -1;
    pointer-events: none;
  }

  /* ===== TABLET ===== */
  @media (max-width: 1024px) {
    .fp-device { width: 260px; }
    .pov-scene { max-width: 95%; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    :global(.portfolio-item .grid) {
      display: flex !important;
      flex-direction: column !important;
      gap: 2rem !important;
    }
    .portfolio-info {
      order: -1 !important;
      text-align: center;
    }
    :global(.portfolio-info .label) { display: inline-block; }
    :global(.portfolio-info ul) { display: inline-flex; flex-direction: column; align-items: flex-start; }
    .portfolio-features { justify-content: center !important; }
    :global(.portfolio-item > div) { padding-top: 2.5rem !important; padding-bottom: 2.5rem !important; }

    /* Item 1: Flatten */
    .floating-screen-scene { perspective: none; padding: 0.5rem 0; }
    .fs-monitor { transform: none !important; padding: 10px; border-radius: 12px; }

    /* Item 2: Flatten */
    .floating-phone-scene { perspective: none; padding: 1rem 0; }
    .fp-device {
      width: 200px;
      transform: none !important;
      animation: none !important;
    }
    .fp-frame { border-width: 4px; border-radius: 2rem; }
    .fp-screen { border-radius: 1.5rem; }
    .fp-island { width: 70px; height: 20px; top: 8px; }
    .fp-shadow { display: none; }
    .fp-btn-power, .fp-btn-vol1, .fp-btn-vol2 { display: none; }
    .fp-reflection { border-radius: 2rem; }

    /* Item 3: Flatten on mobile */
    .fb-scene { perspective: none; padding: 0.5rem 0 1rem; }
    .fb-frame { transform: none !important; padding: 8px; border-radius: 12px; }
    .fb-glow { display: none; }
    .fb-shadow { display: none; }

    :global(.portfolio-features) {
      flex-direction: column !important;
      align-items: center !important;
      gap: 0.5rem !important;
    }
  }

  /* ===== SMALL MOBILE ===== */
  @media (max-width: 480px) {
    .fp-device { width: 170px; }
    .kb-key { width: 10px; height: 8px; }
    .kb-space { width: 55px; }
  }
</style>

<!-- ============================== -->
<!-- SCRIPTS -->
<!-- ============================== -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initPortfolio() {

    // ===== Mobile-first: iframe hydration gate =====
    // Iframes ship with data-src instead of src so browsers can't start
    // loading them on mobile. Promote data-src → src only on desktop.
    // The mobile path keeps the static <img> preview that sits beside
    // each iframe in the markup.
    const isDesktopViewport = window.matchMedia('(min-width: 768px)').matches;
    if (isDesktopViewport) {
      document.querySelectorAll<HTMLIFrameElement>('iframe[data-src]').forEach((iframe) => {
        const src = iframe.getAttribute('data-src');
        if (src) {
          iframe.src = src;
          iframe.removeAttribute('data-src');
        }
      });
    }

    // ===== ITEM 1: Floating Monitor — entrance animation =====
    const fsMonitor = document.getElementById('fs-wrap');
    const item1 = document.querySelector('[data-style="multi-device"]');

    if (fsMonitor && item1) {
      // Entrance: monitor slides up and fades in
      const tl1 = gsap.timeline({
        scrollTrigger: { trigger: item1, start: 'top 70%', toggleActions: 'play none none reverse' }
      });
      tl1.from(fsMonitor, {
        y: 60, opacity: 0, rotateX: 12,
        duration: 1.2, ease: 'expo.out',
      });
      tl1.from(item1.querySelector('.portfolio-info'), { x: 40, opacity: 0, duration: 0.8, ease: 'expo.out' }, '-=0.8');
      tl1.from(item1.querySelectorAll('.portfolio-features li'), { y: 15, opacity: 0, duration: 0.4, stagger: 0.06, ease: 'power2.out' }, '-=0.4');
    }

    // Calculate phone iframe scale to fit viewport
    const fpScreen = document.querySelector('.fp-screen') as HTMLElement;
    if (fpScreen) {
      const updateFpScale = () => {
        const screenW = fpScreen.clientWidth;
        const scale = screenW / 375;
        fpScreen.style.setProperty('--fp-scale', String(scale));
      };
      updateFpScale();
      window.addEventListener('resize', updateFpScale);
    }

    // ===== ITEM 2: Floating phone with mouse follow =====
    // Gated behind (pointer: fine) — on touch devices this ran a pair of
    // infinite requestAnimationFrame loops for zero visual benefit
    // (there's no mouse to follow). On mobile we fall back to the
    // CSS-keyframe fpFloat animation already defined in the stylesheet.
    const hasFinePointer = window.matchMedia('(pointer: fine)').matches;
    const fpScene = document.getElementById('floating-phone-scene');
    const fpDevice = document.getElementById('fp-device');
    if (fpScene && fpDevice && hasFinePointer) {
      let px = -14, py = 4, tpx = -14, tpy = 4;
      function fpLoop() {
        px += (tpx - px) * 0.05;
        py += (tpy - py) * 0.05;
        fpDevice.style.setProperty('--ry', px + 'deg');
        fpDevice.style.setProperty('--rx', py + 'deg');
        fpDevice.style.transform = `rotateY(${px}deg) rotateX(${py}deg) translateY(var(--float-y, 0px))`;
        requestAnimationFrame(fpLoop);
      }
      let floatT = 0;
      function fpFloatLoop() {
        floatT += 0.015;
        const yOff = Math.sin(floatT) * 12;
        fpDevice.style.setProperty('--float-y', yOff + 'px');
        fpDevice.style.transform = `rotateY(${px}deg) rotateX(${py}deg) translateY(${yOff}px)`;
        const shadow = fpDevice.parentElement?.querySelector('.fp-shadow') as HTMLElement;
        if (shadow) {
          const s = 1 - Math.abs(Math.sin(floatT)) * 0.15;
          shadow.style.transform = `scaleX(${s})`;
          shadow.style.opacity = String(0.7 + Math.abs(Math.sin(floatT)) * 0.3);
        }
        requestAnimationFrame(fpFloatLoop);
      }
      fpDevice.style.animation = 'none';
      fpLoop();
      fpFloatLoop();

      fpScene.addEventListener('mousemove', (e: MouseEvent) => {
        const r = fpScene.getBoundingClientRect();
        tpx = ((e.clientX - r.left) / r.width - 0.5) * 20 - 4;
        tpy = (0.5 - (e.clientY - r.top) / r.height) * 14 + 2;
      });
      fpScene.addEventListener('mouseleave', () => { tpx = -14; tpy = 4; });
    }

    // Entrance animation for item 2
    const item2 = document.querySelector('[data-style="floating-phone"]');
    if (item2) {
      const tl2 = gsap.timeline({
        scrollTrigger: { trigger: item2, start: 'top 65%', toggleActions: 'play none none reverse' }
      });
      tl2.from(item2.querySelector('.portfolio-info'), { x: -60, opacity: 0, duration: 0.9, ease: 'expo.out' });
      tl2.from(item2.querySelector('.portfolio-device'), { x: 80, opacity: 0, duration: 1, ease: 'expo.out' }, '-=0.7');
      tl2.from(item2.querySelectorAll('.portfolio-features li'), { y: 15, opacity: 0, duration: 0.4, stagger: 0.06, ease: 'power2.out' }, '-=0.5');
    }

    // ===== ITEM 3: Slide-in entrance only (scroll-scrub handled by shared loop)
    //
    // No bespoke timeline any more — Redwood now uses the same iframe
    // scroll-scrub as items 1 and 2, so it reads as a third beat in the
    // same cadence instead of hijacking scroll with a pin. Depth comes
    // from the 3D-tilted frame CSS, not from scroll choreography.

    const item3 = document.querySelector('[data-style="slide-right"]');
    const fbScene = document.getElementById('fb-scene');

    if (item3 && fbScene) {
      const tl3 = gsap.timeline({
        scrollTrigger: { trigger: item3, start: 'top 70%', toggleActions: 'play none none reverse' }
      });
      tl3.from(item3.querySelector('.zoom-info'), {
        x: 80, opacity: 0, duration: 0.9, ease: 'expo.out',
      });
      tl3.from(item3.querySelectorAll('.portfolio-features span'), {
        y: 12, opacity: 0, stagger: 0.08, duration: 0.4, ease: 'power2.out',
      }, '-=0.5');
      tl3.from(fbScene, {
        x: 160, opacity: 0, scale: 0.94, duration: 1.1, ease: 'expo.out',
      }, '-=0.8');
    }

    // ===== All items: scroll iframe content in sync with section scroll =====
    // Desktop-only. On mobile, three iframes scroll-scrubbed on every tick
    // is the #1 cause of jank — each scrub fires a layout/paint on a full
    // sub-document. Mobile just sees the iframe at its initial offset,
    // which is fine since the device frames are smaller anyway.
    const mmPortfolio = gsap.matchMedia();
    mmPortfolio.add('(min-width: 768px)', () => {
      document.querySelectorAll('.portfolio-item .screen-viewport').forEach((viewport) => {
        const content = viewport.querySelector('.screen-content');
        if (!content) return;
        const section = viewport.closest('.portfolio-item');
        if (!section) return;

        gsap.to(content, {
          y: '-66.6%',
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top 80%',
            end: 'bottom 20%',
            scrub: 1.5,
          },
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortfolio);
  } else {
    initPortfolio();
  }
</script>
