---
const stats = [
  { value: 94, suffix: '%', text: 'of first impressions are design-related', source: 'Research Gate' },
  { value: 53, suffix: '%', text: 'of mobile visits abandoned if load takes over 3 seconds', source: 'Google' },
  { value: 75, suffix: '%', text: 'judge a company\'s credibility by its website design', source: 'Stanford' },
];
---

<section id="problem" class="relative overflow-hidden">
  <div class="section-light py-(--spacing-section)">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16">
        <p class="label mb-4 problem-label">The problem</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-600 tracking-tight problem-heading leading-tight">
          Your competitors are open for business.<br />
          <span class="text-[var(--color-light-muted)]">Are you?</span>
        </h2>
      </div>

      <!-- Three pain points mapping to three tiers -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24" id="pain-cards">

        <!-- Pain 1: Bad website → Essential -->
        <div class="pain-card group">
          <div class="rounded-xl overflow-hidden border border-[var(--color-light-border)] bg-white">
            <!-- Browser chrome -->
            <div class="flex items-center gap-2 px-4 py-2.5 bg-[#f5f5f5] border-b border-[#e5e5e5]">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/30"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/30"></div>
              </div>
              <div class="flex-1 mx-2 h-5 rounded bg-white flex items-center px-2">
                <span class="text-[9px] text-[var(--color-light-muted)] font-mono truncate">www.your-old-site.co.uk</span>
              </div>
            </div>
            <!-- Visible bad site content -->
            <div class="p-4 space-y-3 aspect-[4/3] relative overflow-hidden bg-[#fefefe]">
              <!-- Fake outdated header with bad font -->
              <div class="bg-[#003366] px-3 py-2 rounded-sm">
                <span class="text-white text-[10px] font-bold" style="font-family: 'Comic Sans MS', cursive;">WELCOME TO MY BUSINESS!!!</span>
              </div>
              <!-- Broken image placeholder -->
              <div class="flex items-center gap-2">
                <div class="w-16 h-12 border border-dashed border-gray-300 flex items-center justify-center bg-gray-50 rounded-sm">
                  <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5" /></svg>
                </div>
                <div class="space-y-1 flex-1">
                  <div class="h-1.5 w-full bg-gray-100 rounded"></div>
                  <div class="h-1.5 w-3/4 bg-gray-100 rounded"></div>
                </div>
              </div>
              <!-- Under construction banner -->
              <div class="bg-yellow-100 border border-yellow-300 px-2 py-1 rounded-sm mt-2">
                <span class="text-[8px] text-yellow-700 font-bold">🚧 UNDER CONSTRUCTION - COMING SOON! 🚧</span>
              </div>
              <!-- Fake visitor counter -->
              <div class="text-center mt-2">
                <span class="text-[7px] text-gray-400 font-mono">Visitor counter: 000047</span>
              </div>
              <!-- Copyright from years ago -->
              <div class="absolute bottom-2 left-0 right-0 text-center">
                <span class="text-[7px] text-gray-300">© 2016 All Rights Reserved</span>
              </div>
            </div>
          </div>
          <p class="mt-4 text-sm font-600 text-[var(--color-light-text)] text-center">Your website looks like 2015</p>
          <p class="text-xs text-[var(--color-light-muted)] text-center mt-1">Customers leave before they even call.</p>
        </div>

        <!-- Pain 2: Missed enquiries → Professional -->
        <div class="pain-card group">
          <div class="rounded-xl overflow-hidden border border-[var(--color-light-border)] bg-white">
            <!-- Phone notification header -->
            <div class="flex items-center gap-2 px-4 py-2.5 bg-[#f5f5f5] border-b border-[#e5e5e5]">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/30"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/30"></div>
              </div>
              <div class="flex-1 mx-2 h-5 rounded bg-white flex items-center px-2">
                <span class="text-[9px] text-[var(--color-light-muted)] font-mono truncate">Enquiry inbox</span>
              </div>
            </div>
            <!-- Missed notifications mockup -->
            <div class="p-4 space-y-3 aspect-[4/3] relative overflow-hidden bg-[#fefefe]">
              <div class="bg-red-50 border border-red-200 rounded-lg p-3 flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center shrink-0">
                  <span class="text-red-500 text-xs font-bold">3</span>
                </div>
                <div>
                  <p class="text-[10px] font-600 text-red-700">3 missed enquiries</p>
                  <p class="text-[8px] text-red-500">While you were closed</p>
                </div>
              </div>
              <!-- Individual missed messages -->
              <div class="space-y-2">
                <div class="bg-gray-50 rounded-lg p-2.5 border border-gray-100">
                  <p class="text-[9px] font-500 text-gray-700">"Hi, do you do emergency callouts?"</p>
                  <p class="text-[7px] text-gray-400 mt-1">11:47 PM · No reply</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-2.5 border border-gray-100">
                  <p class="text-[9px] font-500 text-gray-700">"Can I book an appointment for Monday?"</p>
                  <p class="text-[7px] text-gray-400 mt-1">1:23 AM · No reply</p>
                </div>
                <div class="bg-gray-50 rounded-lg p-2.5 border border-gray-100">
                  <p class="text-[9px] font-500 text-gray-700">"How much for a full service?"</p>
                  <p class="text-[7px] text-gray-400 mt-1">5:15 AM · No reply</p>
                </div>
              </div>
            </div>
          </div>
          <p class="mt-4 text-sm font-600 text-[var(--color-light-text)] text-center">You're missing enquiries at midnight</p>
          <p class="text-xs text-[var(--color-light-muted)] text-center mt-1">Every unanswered message is a customer lost.</p>
        </div>

        <!-- Pain 3: Missed calls → Premium -->
        <div class="pain-card group">
          <div class="rounded-xl overflow-hidden border border-[var(--color-light-border)] bg-white">
            <!-- Phone chrome -->
            <div class="flex items-center gap-2 px-4 py-2.5 bg-[#f5f5f5] border-b border-[#e5e5e5]">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/30"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/30"></div>
              </div>
              <div class="flex-1 mx-2 h-5 rounded bg-white flex items-center px-2">
                <span class="text-[9px] text-[var(--color-light-muted)] font-mono truncate">Recent calls</span>
              </div>
            </div>
            <!-- Call log mockup -->
            <div class="p-4 aspect-[4/3] relative overflow-hidden bg-[#fefefe]">
              <div class="space-y-1">
                {['9:12 AM', '10:45 AM', '12:30 PM', '2:15 PM', '4:50 PM'].map((time, i) => (
                  <div class="flex items-center gap-3 py-2 border-b border-gray-50">
                    <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <div class="flex-1">
                      <p class="text-[10px] font-500 text-gray-700">07XXX XXX {String(i * 111 + 234).slice(0,3)}</p>
                      <p class="text-[8px] text-red-400">Missed call · {time}</p>
                    </div>
                    <span class="text-[7px] text-gray-400">Went to voicemail</span>
                  </div>
                ))}
              </div>
              <div class="absolute bottom-3 left-0 right-0 text-center">
                <span class="text-[9px] font-600 text-red-500">5 missed calls today</span>
              </div>
            </div>
          </div>
          <p class="mt-4 text-sm font-600 text-[var(--color-light-text)] text-center">Every missed call goes to your competitor</p>
          <p class="text-xs text-[var(--color-light-muted)] text-center mt-1">They called. Nobody answered. They won't call back.</p>
        </div>
      </div>

      <!-- Stats with sources -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16" id="problem-stats">
        {stats.map((stat) => (
          <div class="stat-card text-center">
            <p class="text-5xl md:text-6xl font-heading font-600 text-accent mb-3 tracking-tight">
              <span class="stat-value" data-value={stat.value}>0</span>{stat.suffix}
            </p>
            <p class="text-sm text-[var(--color-light-text-secondary)] leading-relaxed max-w-xs mx-auto">
              {stat.text}
            </p>
            <p class="text-[10px] text-[var(--color-light-muted)] font-mono mt-2 uppercase tracking-wider">
              {stat.source}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Transition — video with circular vignette -->
  <div id="problem-transition" class="relative h-[500px] md:h-[600px] overflow-hidden section-light">
    <div class="absolute inset-0 bg-[var(--color-light-bg)]"></div>

    <!-- Video — large circular mask, centred on subject -->
    <div class="absolute inset-0 flex items-center justify-center opacity-[0.35]"
      style="mask-image: radial-gradient(ellipse 55% 65% at 50% 50%, black 25%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse 55% 65% at 50% 50%, black 25%, transparent 75%);">
      <video
        id="transition-video"
        class="w-full h-full object-cover"
        style="object-position: 45% 25%;"
        muted
        loop
        playsinline
        preload="metadata"
        poster="/video/hero-poster.jpg"
      >
        <source src="/video/hero-bg.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- Text on top — accent colour, readable against the faded video -->
    <div class="absolute inset-0 flex items-center justify-center">
      <span class="transition-text block text-3xl md:text-5xl opacity-0 text-center px-6 tracking-tight" style="font-family: 'Sora', sans-serif; font-weight: 700; color: #1a1a2e;">
        There is a better way.
      </span>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initProblem() {
    gsap.from('.problem-label', {
      scrollTrigger: { trigger: '#problem', start: 'top 80%' },
      y: 20, opacity: 0, duration: 0.6, ease: 'expo.out',
    });
    gsap.from('.problem-heading', {
      scrollTrigger: { trigger: '#problem', start: 'top 75%' },
      y: 40, opacity: 0, duration: 0.8, ease: 'expo.out',
    });

    // Pain cards stagger in
    const cards = document.querySelectorAll('.pain-card');
    cards.forEach((card, i) => {
      gsap.from(card, {
        scrollTrigger: {
          trigger: '#pain-cards',
          start: 'top 80%',
          toggleActions: 'play none none reverse',
        },
        y: 60, opacity: 0, duration: 0.8, delay: i * 0.15, ease: 'expo.out',
      });
    });

    // Stat counters
    document.querySelectorAll('.stat-value').forEach((el) => {
      const target = parseInt((el as HTMLElement).dataset.value || '0', 10);
      const obj = { value: 0 };
      gsap.to(obj, {
        scrollTrigger: { trigger: el, start: 'top 85%' },
        value: target,
        duration: 1.5,
        ease: 'quart.out',
        onUpdate: () => {
          el.textContent = Math.round(obj.value).toString();
        },
      });
    });

    // Video — play when scrolled into view, pause when out
    const video = document.getElementById('transition-video') as HTMLVideoElement;
    if (video) {
      ScrollTrigger.create({
        trigger: '#problem-transition',
        start: 'top 85%',
        end: 'bottom 15%',
        onEnter: () => video.play(),
        onLeave: () => video.pause(),
        onEnterBack: () => video.play(),
        onLeaveBack: () => video.pause(),
      });
    }

    // "There is a better way." reveal
    gsap.to('.transition-text', {
      scrollTrigger: {
        trigger: '#problem-transition',
        start: 'top 70%',
        end: 'bottom 50%',
        scrub: 0.5,
      },
      opacity: 1, y: -20, scale: 1.05,
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProblem);
  } else {
    initProblem();
  }
</script>
