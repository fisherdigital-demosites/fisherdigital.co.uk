---
---

<section id="about" class="section-light py-(--spacing-section)">
  <div class="mx-auto max-w-5xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
      <!-- Photo -->
      <div class="lg:col-span-2">
        <div class="about-photo aspect-[3/4] rounded-2xl overflow-hidden bg-[var(--color-light-surface)] border border-[var(--color-light-border)] shadow-lg">
          <!-- Placeholder — will be replaced with Gemini-generated or stock image -->
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&h=800&fit=crop&crop=faces"
            alt="Team collaboration in a modern workspace"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Bio — "we" language, no AI process mentions -->
      <div class="lg:col-span-3 about-content">
        <span class="label block mb-4">About us</span>
        <h2 class="text-3xl md:text-4xl font-heading font-600 tracking-tight mb-8 text-[var(--color-light-text)]">
          Small team.<br />
          <span class="text-[var(--color-light-muted)]">Big results.</span>
        </h2>

        <div class="space-y-5 text-[var(--color-light-text-secondary)] leading-relaxed">
          <p>
            Founded by Joshua Fisher in Bristol. We build websites, set up chatbots,
            and configure AI tools for local businesses across the UK.
          </p>
          <p>
            We build your site before you spend a penny. You see a working demo,
            walk through it with us, and only pay if you want to go live. Most of
            our clients are up and running within two weeks.
          </p>
          <p>
            Every site we build is designed to do one thing: bring you more customers.
            Whether that's ranking on Google, capturing enquiries at midnight, or
            answering your phone when you're busy.
          </p>
          <p class="text-[var(--color-light-text)] font-medium">
            If your website isn't bringing in business, let's talk.
          </p>
        </div>

        <!-- Credentials -->
        <div class="mt-10 pt-8 border-t border-[var(--color-light-border)] flex flex-wrap items-center gap-6">
          <div class="text-center">
            <p class="text-2xl font-heading font-600 text-accent">&lt;24hr</p>
            <p class="text-xs text-[var(--color-light-muted)]">Response time</p>
          </div>
          <div class="w-px h-8 bg-[var(--color-light-border)]"></div>
          <div class="text-center">
            <p class="text-2xl font-heading font-600 text-accent">&lt;1s</p>
            <p class="text-xs text-[var(--color-light-muted)]">Avg. load time</p>
          </div>
          <div class="w-px h-8 bg-[var(--color-light-border)]"></div>
          <div class="text-center">
            <p class="text-2xl font-heading font-600 text-accent">100%</p>
            <p class="text-xs text-[var(--color-light-muted)]">UK-based</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initAbout() {
    gsap.from('.about-photo', {
      scrollTrigger: { trigger: '#about', start: 'top 75%' },
      x: -60,
      opacity: 0,
      duration: 1,
      ease: 'expo.out',
    });
    gsap.from('.about-content', {
      scrollTrigger: { trigger: '#about', start: 'top 75%' },
      x: 40,
      opacity: 0,
      duration: 1,
      delay: 0.15,
      ease: 'expo.out',
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAbout);
  } else {
    initAbout();
  }
</script>
