---
// Homepage teaser for the /industries hub. Keeps the homepage tight — just
// five niche pills + a single CTA — without repeating the full hub content.
const niches = [
  { name: 'Plumbers', slug: '/web-design-for-plumbers' },
  { name: 'Electricians', slug: '/web-design-for-electricians' },
  { name: 'Dentists', slug: '/web-design-for-dentists' },
  { name: 'Hair salons', slug: '/web-design-for-hair-salons' },
  { name: 'Restaurants', slug: '/web-design-for-restaurants' },
];
---

<section id="industries-teaser" class="section-light py-(--spacing-section) border-t border-[var(--color-light-border)]/50">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-5">
        <span class="label block mb-4">Industries</span>
        <h2 class="text-4xl md:text-5xl font-heading font-600 tracking-tight mb-6 text-[var(--color-light-text)]">
          Built for<br />
          <span class="text-accent italic">specific trades.</span>
        </h2>
        <p class="text-lg text-[var(--color-light-text-secondary)] leading-relaxed mb-8 max-w-md">
          Generic studios build the same site for everyone. We build around how
          your trade actually gets hired.
        </p>
        <a href="/industries" data-hover
          class="inline-flex items-center gap-2 text-sm font-600 text-accent hover:text-accent-hover transition-colors">
          See all industries
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="lg:col-span-7">
        <div class="flex flex-wrap gap-3">
          {niches.map((n) => (
            <a
              href={n.slug}
              data-hover
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full border border-[var(--color-light-border)] bg-white text-sm font-600 text-[var(--color-light-text)] hover:border-accent/40 hover:text-accent hover:-translate-y-0.5 transition-all shadow-sm hover:shadow-md"
            >
              {n.name}
              <svg class="w-3.5 h-3.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
