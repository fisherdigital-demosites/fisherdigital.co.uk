---
const trustSignals = [
  { label: 'You see it before you pay', value: 'Free' },
  { label: 'Response time', value: '<24hr' },
  { label: 'First call to live site', value: '14 days' },
  { label: 'Based in the', value: 'UK' },
];
---

<section id="social-proof" class="section-light py-(--spacing-section) relative overflow-hidden border-y border-[var(--color-light-border)]/50">
  <div class="mx-auto max-w-7xl px-6 relative z-10">
    <div class="text-center mb-16">
      <span class="label block mb-4">Results</span>
      <h2 class="text-4xl md:text-5xl font-heading font-600 tracking-tight">
        Built on results,<br />
        <span class="text-[var(--color-light-muted)]">not promises</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {trustSignals.map((signal) => (
        <div class="trust-card text-center rounded-xl bg-white border border-[var(--color-light-border)] py-8 px-4">
          <p class="text-3xl md:text-4xl mb-2 tracking-tight text-accent" style="font-family: 'Sora', sans-serif; font-weight: 700;">{signal.value}</p>
          <p class="text-xs text-[var(--color-light-muted)]">{signal.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-card {
    opacity: 0;
    transform: translateY(30px);
  }
  .trust-card.revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .trust-card:nth-child(2).revealed { transition-delay: 0.08s; }
  .trust-card:nth-child(3).revealed { transition-delay: 0.16s; }
  .trust-card:nth-child(4).revealed { transition-delay: 0.24s; }
</style>

<script>
  function initSocialProof() {
    const section = document.getElementById('social-proof');
    if (!section) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.querySelectorAll('.trust-card').forEach((card) => {
            card.classList.add('revealed');
          });
        }
      },
      { threshold: 0.15 }
    );
    observer.observe(section);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSocialProof);
  } else {
    initSocialProof();
  }
</script>
