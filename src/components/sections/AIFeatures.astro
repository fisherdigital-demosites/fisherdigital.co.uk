---
const chatMessages = [
  { from: 'visitor', text: 'Hi, do you do emergency callouts on weekends?', delay: 0 },
  { from: 'bot', text: 'Yes! We offer 24/7 emergency plumbing services across North Bristol. Weekend callouts are available with no extra charge for the first hour. Would you like to book one now?', delay: 1.5 },
  { from: 'visitor', text: 'Yes please, my boiler is leaking', delay: 3.5 },
  { from: 'bot', text: 'I\'m sorry to hear that. I\'ve flagged this as urgent. Can I take your postcode and a contact number? Our nearest engineer can be with you within 90 minutes.', delay: 5 },
];
---

<section id="ai-features" class="section-light py-(--spacing-section) border-t border-[var(--color-light-border)]/50">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-20">
      <span class="label block mb-4">Smart features</span>
      <h2 class="text-4xl md:text-5xl font-heading font-600 tracking-tight">
        Your website, working<br />
        <span class="text-[var(--color-light-muted)]">while you sleep</span>
      </h2>
      <p class="text-lg text-[var(--color-light-text-secondary)] max-w-2xl mx-auto mt-6">
        Every Professional and Premium site includes tools that handle
        enquiries, book appointments, and answer calls so you never miss a lead.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
      <!-- Chatbot Demo -->
      <div class="ai-feature-card">
        <div class="mb-6">
          <h3 class="text-2xl font-heading font-600 text-[var(--color-light-text)] mb-2">
            Smart enquiry capture
          </h3>
          <p class="text-[var(--color-light-text-secondary)] text-sm leading-relaxed">
            Trained on your business. Answers questions, qualifies leads, and books appointments
            even at 2am on a Sunday.
          </p>
        </div>

        <!-- Chat mockup -->
        <div class="rounded-2xl border border-[var(--color-light-border)] bg-white overflow-hidden shadow-sm">
          <!-- Chat header — cleaner design -->
          <div class="flex items-center gap-3 px-5 py-4 border-b border-[var(--color-light-border)] bg-white">
            <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center">
              <span class="text-white text-sm font-heading font-600">WP</span>
            </div>
            <div class="flex-1">
              <p class="text-sm font-heading font-600 text-[var(--color-light-text)]">Westbury Plumbing</p>
              <div class="flex items-center gap-1.5">
                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                <p class="text-xs text-green-600">Online now</p>
              </div>
            </div>
            <button class="w-8 h-8 rounded-full bg-[var(--color-light-bg)] flex items-center justify-center">
              <svg class="w-4 h-4 text-[var(--color-light-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <!-- Chat messages -->
          <div class="p-4 space-y-3 min-h-[280px]" id="chat-demo">
            {chatMessages.map((msg, i) => (
              <div
                class:list={[
                  'chat-msg flex gap-2 opacity-0',
                  msg.from === 'visitor' ? 'justify-end' : 'justify-start',
                ]}
                data-delay={msg.delay}
              >
                <div class:list={[
                  'max-w-[80%] rounded-2xl px-4 py-2.5 text-sm leading-relaxed',
                  msg.from === 'visitor'
                    ? 'bg-accent text-white rounded-br-md'
                    : 'bg-[var(--color-light-surface)] text-[var(--color-light-text)] rounded-bl-md',
                ]}>
                  {msg.text}
                </div>
              </div>
            ))}

            <!-- Typing indicator -->
            <div id="typing-indicator" class="flex gap-2 justify-start opacity-0">
              <div class="bg-[var(--color-light-surface)] rounded-2xl rounded-bl-md px-4 py-3 flex items-center gap-1">
                <span class="typing-dot w-1.5 h-1.5 rounded-full bg-[var(--color-light-muted)]"></span>
                <span class="typing-dot w-1.5 h-1.5 rounded-full bg-[var(--color-light-muted)]"></span>
                <span class="typing-dot w-1.5 h-1.5 rounded-full bg-[var(--color-light-muted)]"></span>
              </div>
            </div>
          </div>

          <!-- Input bar -->
          <div class="border-t border-[var(--color-light-border)] p-3 flex items-center gap-2">
            <div class="flex-1 bg-[var(--color-light-bg)] rounded-full px-4 py-2 text-sm text-[var(--color-light-muted)]">
              Type a message...
            </div>
            <button class="w-9 h-9 rounded-full bg-accent flex items-center justify-center text-white shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Receptionist Demo -->
      <div class="ai-feature-card">
        <div class="mb-6">
          <h3 class="text-2xl font-heading font-600 text-[var(--color-light-text)] mb-2">
            Never miss a call again
          </h3>
          <p class="text-[var(--color-light-text-secondary)] text-sm leading-relaxed">
            A natural-sounding AI answers your phone, takes messages, books appointments,
            and forwards urgent calls. Just like a real receptionist.
          </p>
        </div>

        <!-- Phone call mockup — redesigned -->
        <div class="rounded-2xl border border-[var(--color-light-border)] bg-white overflow-hidden shadow-sm">
          <!-- Call header — lighter, modern -->
          <div class="px-6 py-6 bg-white border-b border-[var(--color-light-border)]">
            <div class="flex items-center gap-4">
              <div class="relative">
                <div class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <span class="absolute -bottom-0.5 -right-0.5 w-4 h-4 rounded-full bg-green-500 border-2 border-white"></span>
              </div>
              <div class="flex-1">
                <p class="text-base font-heading font-600 text-[var(--color-light-text)]">Bright Smile Dental</p>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Incoming call from 07XXX XXX XXX</p>
              </div>
              <div class="text-right">
                <p id="call-timer" class="text-sm font-heading font-500 text-accent">00:00</p>
                <p class="text-xs text-green-600 flex items-center gap-1 justify-end">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  Live
                </p>
              </div>
            </div>
          </div>

          <!-- Audio player with waveform -->
          <div class="px-6 py-5 bg-[var(--color-light-bg)]">
            <audio id="demo-audio" src="/audio/demo-call.mp3" preload="metadata"></audio>

            <!-- Play button + waveform -->
            <div class="flex items-center gap-4">
              <button id="play-btn" class="w-12 h-12 rounded-full bg-accent flex items-center justify-center text-white shrink-0 hover:bg-accent-hover transition-colors shadow-lg shadow-accent/20 cursor-pointer" aria-label="Play demo call">
                <svg id="play-icon" class="w-5 h-5 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
                <svg id="pause-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                </svg>
              </button>
              <div class="flex-1">
                <div class="flex items-center justify-center gap-[2px] h-10" id="waveform">
                  {Array.from({ length: 48 }).map((_, i) => (
                    <div
                      class="waveform-bar w-[2px] rounded-full bg-accent/30 transition-all duration-150"
                      style={`height: 4px`}
                    ></div>
                  ))}
                </div>
              </div>
              <span id="audio-time" class="text-xs font-heading font-500 text-[var(--color-light-muted)] w-12 text-right">0:55</span>
            </div>

            <p class="text-center text-xs text-[var(--color-light-muted)] mt-3" id="play-label">
              Listen to a demo call
            </p>
          </div>

          <!-- Transcript preview -->
          <div class="border-t border-[var(--color-light-border)] px-5 py-4 bg-white">
            <p class="text-[10px] font-500 text-[var(--color-light-muted)] uppercase tracking-wider mb-3">Live transcript</p>
            <div class="space-y-2.5 max-h-[240px] overflow-y-auto" id="call-transcript">
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-accent text-[9px] font-600">AI</span>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Good morning, Bright Smile Dental.</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-[var(--color-light-surface)] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[var(--color-light-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Hi yeah, I was wondering if I could book a check-up?</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-accent text-[9px] font-600">AI</span>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Are you a new patient, or have you been with us before?</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-[var(--color-light-surface)] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[var(--color-light-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">New patient yeah. My friend recommended you actually.</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-accent text-[9px] font-600">AI</span>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Lovely. I've got this Thursday at ten, or Friday at half two. Which works better?</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-[var(--color-light-surface)] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[var(--color-light-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Thursday morning would be great, actually.</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-accent text-[9px] font-600">AI</span>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Perfect. Can I take your name?</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-[var(--color-light-surface)] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[var(--color-light-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Yeah it's Sarah Mitchell, it's for my wife.</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-accent text-[9px] font-600">AI</span>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Sarah Mitchell, Thursday the eleventh at ten. We'll send a confirmation text shortly.</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-[var(--color-light-surface)] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-[var(--color-light-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">No that's perfect, thank you.</p>
              </div>
              <div class="transcript-line flex gap-3 opacity-0">
                <span class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-accent text-[9px] font-600">AI</span>
                </span>
                <p class="text-sm text-[var(--color-light-text-secondary)]">Great, we'll see you Thursday. Have a lovely day.</p>
              </div>
            </div>
          </div>

          <!-- Action bar -->
          <div class="border-t border-[var(--color-light-border)] px-5 py-3 flex items-center justify-between bg-white">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-xs text-green-600">Call in progress</span>
            </div>
            <button class="text-xs text-[var(--color-light-muted)] hover:text-accent transition-colors font-500">
              Take over call
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
  }
  .typing-dot:nth-child(1) { animation: typingBounce 1.4s ease-in-out infinite; }
  .typing-dot:nth-child(2) { animation: typingBounce 1.4s ease-in-out 0.2s infinite; }
  .typing-dot:nth-child(3) { animation: typingBounce 1.4s ease-in-out 0.4s infinite; }

  @keyframes waveformPulse {
    0%, 100% { height: 4px; }
    50% { height: var(--wave-h, 20px); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initAIFeatures() {
    gsap.from('.ai-feature-card', {
      scrollTrigger: { trigger: '#ai-features', start: 'top 70%' },
      y: 60, opacity: 0, duration: 0.8, stagger: 0.2, ease: 'expo.out',
    });

    let chatTriggered = false;
    ScrollTrigger.create({
      trigger: '#chat-demo',
      start: 'top 80%',
      onEnter: () => {
        if (chatTriggered) return;
        chatTriggered = true;

        const msgs = document.querySelectorAll('.chat-msg');
        const typingIndicator = document.getElementById('typing-indicator');

        msgs.forEach((msg, i) => {
          const delay = parseFloat((msg as HTMLElement).dataset.delay || '0');
          const isBotMsg = msg.querySelector('.bg-\\[var\\(--color-light-surface\\)\\]');

          if (isBotMsg && typingIndicator) {
            gsap.to(typingIndicator, { opacity: 1, duration: 0.2, delay: delay - 0.8 });
            gsap.to(typingIndicator, { opacity: 0, duration: 0.2, delay: delay - 0.1 });
          }

          gsap.to(msg, {
            opacity: 1, y: 0, duration: 0.4,
            delay: delay, ease: 'back.out(1.2)',
          });
          gsap.from(msg, {
            y: 10, duration: 0.4,
            delay: delay, ease: 'back.out(1.2)',
          });
        });
      },
    });

    // Audio player
    const audio = document.getElementById('demo-audio') as HTMLAudioElement;
    const playBtn = document.getElementById('play-btn');
    const playIcon = document.getElementById('play-icon');
    const pauseIcon = document.getElementById('pause-icon');
    const audioTime = document.getElementById('audio-time');
    const playLabel = document.getElementById('play-label');
    const timer = document.getElementById('call-timer');
    const bars = document.querySelectorAll('.waveform-bar');
    const lines = document.querySelectorAll('.transcript-line');

    let isPlaying = false;
    let waveInterval: ReturnType<typeof setInterval>;

    // Transcript timestamps synced to actual audio
    const transcriptTimes = [1.7, 4.0, 7.2, 10.9, 14.5, 24.1, 26.4, 28.4, 38.2, 48.2, 50.2];

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function startWaveform() {
      bars.forEach((bar) => {
        const el = bar as HTMLElement;
        const maxH = 6 + Math.random() * 22;
        el.style.setProperty('--wave-h', maxH + 'px');
        el.style.animation = `waveformPulse ${0.6 + Math.random() * 0.8}s ease-in-out ${Math.random() * 0.5}s infinite`;
      });
    }

    function stopWaveform() {
      bars.forEach((bar) => {
        const el = bar as HTMLElement;
        el.style.animation = 'none';
        el.style.height = '4px';
      });
    }

    if (playBtn && audio) {
      playBtn.addEventListener('click', () => {
        if (isPlaying) {
          audio.pause();
          isPlaying = false;
          playIcon?.classList.remove('hidden');
          pauseIcon?.classList.add('hidden');
          stopWaveform();
          if (playLabel) playLabel.textContent = 'Paused';
        } else {
          audio.play();
          isPlaying = true;
          playIcon?.classList.add('hidden');
          pauseIcon?.classList.remove('hidden');
          startWaveform();
          if (playLabel) playLabel.textContent = 'Your AI receptionist is handling this call';
        }
      });

      // Update time display and transcript
      audio.addEventListener('timeupdate', () => {
        const current = audio.currentTime;
        const remaining = audio.duration - current;
        if (audioTime && !isNaN(remaining)) {
          audioTime.textContent = formatTime(remaining);
        }
        if (timer) {
          timer.textContent = formatTime(current);
        }

        // Reveal transcript lines at timestamps + keep latest visible
        const transcript = document.getElementById('call-transcript');
        transcriptTimes.forEach((t, i) => {
          if (current >= t && lines[i]) {
            const line = lines[i] as HTMLElement;
            if (line.style.opacity !== '1') {
              gsap.to(line, { opacity: 1, duration: 0.4, ease: 'power2.out' });
              if (transcript) {
                // Scroll so the new line is near the top of the visible area
                setTimeout(() => {
                  transcript.scrollTo({ top: Math.max(0, line.offsetTop - transcript.offsetTop - 10), behavior: 'smooth' });
                }, 100);
              }
            }
          }
        });
      });

      // Reset on end
      audio.addEventListener('ended', () => {
        isPlaying = false;
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
        stopWaveform();
        if (playLabel) playLabel.textContent = 'Play again';
        if (timer) timer.textContent = '00:00';
        if (audioTime) audioTime.textContent = formatTime(audio.duration);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAIFeatures);
  } else {
    initAIFeatures();
  }
</script>
