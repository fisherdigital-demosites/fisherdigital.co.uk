---
import Button from '../ui/Button.astro';
import { serviceTiers } from '../../data/services';
---

<section id="services" class="section-light py-(--spacing-section)">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center mb-20">
      <span class="label block mb-4">Pricing</span>
      <h2 class="text-4xl md:text-5xl font-heading font-600 tracking-tight">
        Three plans. One goal.<br />
        <span class="text-[var(--color-light-muted)]">More customers through your door.</span>
      </h2>
      <p class="text-lg text-[var(--color-light-text-secondary)] max-w-2xl mx-auto mt-6">
        Every plan includes hosting, SSL, mobile optimisation, and 12 months of support. No hidden fees. Cancel the monthly any time.
      </p>
    </div>

    <div class="pricing-grid grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto items-stretch">
      {serviceTiers.map((tier) => (
        <div class:list={[
          'pricing-card relative rounded-2xl p-8 lg:p-10 flex flex-col',
          tier.highlighted
            ? 'bg-white border-2 border-accent shadow-xl shadow-accent/10 ring-1 ring-accent/10'
            : 'bg-white border border-[var(--color-light-border)] hover:border-[var(--color-light-muted)]/30 hover:shadow-lg transition-all duration-300',
        ]}>
          {tier.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-accent text-xs font-semibold text-white">
              Most popular
            </div>
          )}

          <div>
            <h3 class="text-xl font-heading font-600 text-[var(--color-light-text)] mb-3">{tier.name}</h3>
            <div class="flex items-baseline gap-1.5 mb-1">
              <span class="text-4xl tracking-tight text-[var(--color-light-text)]" style="font-family: 'Sora', sans-serif; font-weight: 700;">{tier.price.replace('From ', '')}</span>
            </div>
            <p class="text-xs text-[var(--color-light-muted)] mb-4">{tier.monthly} after launch</p>
            <p class="text-sm text-[var(--color-light-text-secondary)] mb-8 leading-relaxed">{tier.tagline}</p>
          </div>

          <ul class="space-y-3 flex-1">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-[var(--color-light-text-secondary)]">
                <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <div class="mt-10">
            <Button
              href="#contact"
              variant={tier.highlighted ? 'primary' : 'outline'}
              class="w-full"
            >
              Book a free call
            </Button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-card {
    opacity: 0;
    transform: translateY(40px);
  }
  .pricing-card.revealed {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .pricing-card:nth-child(2).revealed { transition-delay: 0.12s; }
  .pricing-card:nth-child(3).revealed { transition-delay: 0.24s; }
</style>

<script>
  function initPricing() {
    const section = document.getElementById('services');
    if (!section) return;

    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.querySelectorAll('.pricing-card').forEach((card) => {
            card.classList.add('revealed');
          });
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(section);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPricing);
  } else {
    initPricing();
  }
</script>
