---
import SplineScene from '../three/SplineScene';
---

<section id="hero" class="relative min-h-[110vh] flex items-center overflow-hidden bg-base">
  <!-- Background layers -->
  <div class="absolute inset-0">
    <!-- Soft radial glow -->
    <div id="hero-layer-2" class="absolute inset-0">
      <div class="absolute top-[15%] right-[15%] w-[600px] h-[600px] rounded-full bg-accent/[0.05] blur-[160px]"></div>
      <div class="absolute bottom-[20%] left-[10%] w-[400px] h-[400px] rounded-full bg-accent/[0.03] blur-[120px]"></div>
    </div>

    <!-- Dot grid -->
    <div id="hero-layer-3" class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle, var(--color-text-muted) 1px, transparent 1px); background-size: 28px 28px;">
    </div>

  </div>

  <!-- Spline 3D laptop scene — above background, beside text.
       client:media so the ~500kb Spline runtime only downloads on viewports
       that'll actually render it. The hidden md:block already handles
       visual suppression on mobile, but client:idle was still pulling
       the JS on phones for no reason. -->
  <div id="hero-3d" class="absolute top-0 right-0 w-[60%] h-full hidden md:block z-[5] pointer-events-auto">
    <SplineScene client:media="(min-width: 768px)" />
  </div>

  <!-- Content — full width, left aligned -->
  <div id="hero-content" class="relative z-10 mx-auto max-w-7xl px-6 w-full pointer-events-none">
    <div class="max-w-2xl">
      <h1 id="hero-headline" class="text-hero font-heading font-600 leading-[0.95] tracking-[-0.02em] mb-8 text-text">
        <span class="hero-line block">More customers.</span>
        <span class="hero-line block">Less <span class="text-accent italic">chasing.</span></span>
      </h1>

      <p id="hero-sub" class="text-lg md:text-xl text-text-muted max-w-lg mb-14 opacity-0" style="font-family: 'Sora', sans-serif; font-weight: 500; letter-spacing: -0.01em;">
        Built for local businesses that want to grow.
      </p>

      <div id="hero-ctas" class="flex flex-col sm:flex-row items-start gap-5 opacity-0 pointer-events-auto">
        <a href="#portfolio" data-hover data-magnetic
          class="group inline-flex items-center gap-3 bg-accent text-white px-8 py-4 rounded-full text-sm font-600 hover:bg-accent-hover transition-all shadow-lg shadow-accent/20 hover:shadow-accent/40">
          See what we build
          <svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="#contact" data-hover
          class="inline-flex items-center gap-3 text-text-secondary px-8 py-4 rounded-full text-sm font-500 border border-border-light hover:border-accent hover:text-accent transition-all">
          Book a free call
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div id="hero-scroll" class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-0">
    <div class="flex flex-col items-center gap-3">
      <span class="text-[10px] font-mono text-text-muted uppercase tracking-[0.2em]">Scroll</span>
      <div class="w-[1px] h-8 bg-gradient-to-b from-text-muted/40 to-transparent scroll-line"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.3); transform-origin: top; }
  }
  .scroll-line { animation: scrollPulse 2s ease-in-out infinite; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  gsap.registerPlugin(ScrollTrigger, SplitText);

  function initHero() {
    // ---- Mobile fallback FIRST ----
    // The markup ships with #hero-sub, #hero-ctas, and #hero-scroll at
    // opacity-0, relying on the GSAP master timeline to reveal them.
    // Two problems on mobile:
    //   1) The SplitText-based character animation is heavy and sometimes
    //      stalls on low-end devices, leaving the subhead invisible
    //      (the "things don't appear" bug).
    //   2) Pinning the hero for a 180% scroll-jacked word-cycle feels
    //      terrible on touch — the page fights the finger.
    // Fix: gate every heavy / pin-based animation behind a desktop
    // matchMedia, and on mobile just set the opacity-0 elements visible
    // immediately with a single fade. Desktop experience is unchanged.

    const isMobile = window.matchMedia('(max-width: 767px)').matches;

    if (isMobile) {
      // Make everything that was pre-hidden for the animation visible.
      gsap.set(['#hero-sub', '#hero-ctas', '#hero-scroll'], { opacity: 1, y: 0, clearProps: 'filter' });

      // Soft fade-in for the hero content so it doesn't just pop.
      gsap.from('#hero-content', {
        opacity: 0, y: 16, duration: 0.7, ease: 'power2.out', delay: 0.1,
      });
      return;
    }

    // ---- Desktop path (original, wrapped in matchMedia for safety) ----
    const mm = gsap.matchMedia();

    mm.add('(min-width: 768px)', () => {
      // Parallax
      gsap.to('#hero-layer-2', {
        y: -80, ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 0.3 },
      });
      gsap.to('#hero-layer-3', {
        y: -40, ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 0.15 },
      });

      // Pin the hero and cycle laptop screen words while scrolling
      const words = document.querySelectorAll('.screen-word');
      if (words.length > 1) {
        const wordTl = gsap.timeline({
          scrollTrigger: {
            trigger: '#hero',
            start: '15% top',
            end: '+=180%',
            pin: true,
            scrub: 1,
          },
        });

        wordTl.to({}, { duration: 0.2 });

        for (let i = 1; i < words.length; i++) {
          wordTl.to(words[i - 1], {
            opacity: 0, y: -40, scale: 0.85, filter: 'blur(6px)',
            duration: 0.25, ease: 'power2.in',
          });
          wordTl.fromTo(words[i],
            { opacity: 0, y: 30, scale: 1.1, filter: 'blur(4px)' },
            { opacity: 1, y: 0, scale: 1, filter: 'blur(0px)', duration: 0.25, ease: 'power2.out' },
            '-=0.08'
          );
          wordTl.to({}, { duration: 0.35 });
        }

        wordTl.to(words[words.length - 1], {
          opacity: 0, y: -40, scale: 0.85, filter: 'blur(6px)', duration: 0.25,
        });
      }

      // Text entrance — SplitText is desktop-only. Adds ~15kb and is the
      // most common culprit for invisible headlines on low-end mobile.
      const headline = document.getElementById('hero-headline');
      if (!headline) return;

      const lines = headline.querySelectorAll('.hero-line');
      const allSplits: any[] = [];
      lines.forEach(line => {
        allSplits.push(new SplitText(line, { type: 'chars,words' }));
      });

      const master = gsap.timeline({ delay: 1.8 });

      allSplits.forEach((split, i) => {
        master.from(split.chars, {
          y: 100, rotateX: -60, opacity: 0,
          duration: 1, ease: 'expo.out', stagger: 0.02,
        }, i === 0 ? '0' : '-=0.7');
      });

      master.to('#hero-sub', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.4')
        .from('#hero-sub', { y: 15 }, '-=0.6');

      master.to('#hero-ctas', { opacity: 1, duration: 0 }, '-=0.4')
        .from('#hero-ctas', { y: 20, duration: 0.7, ease: 'expo.out' }, '-=0.4');

      master.to('#hero-scroll', { opacity: 1, duration: 0.5 }, '-=0.1');

      // Content parallax out
      const content = document.getElementById('hero-content');
      if (content) {
        gsap.to(content, {
          y: -80, opacity: 0, filter: 'blur(6px)',
          scrollTrigger: { trigger: '#hero', start: '40% top', end: 'bottom top', scrub: 0.3 },
        });
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
